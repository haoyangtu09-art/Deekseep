<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.dsmod.inject"
    android:versionCode="7"
    android:versionName="1.7-inject-api102">

    <uses-sdk android:minSdkVersion="24" android:targetSdkVersion="34" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <application
        android:label="DeekseepX"
        android:description="@string/moddesc"
        android:allowBackup="false">

        <activity
            android:name="com.dsmod.inject.SettingsActivity"
            android:exported="true"
            android:label="DeekseepX"
            android:theme="@android:style/Theme.DeviceDefault.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.dsmod.inject.PromptPickerActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.DeviceDefault.Light.NoActionBar" />
    </application>
</manifest>
